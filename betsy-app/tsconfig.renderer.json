{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "dist/renderer",
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src/renderer/**/*", "src/main/wizard-engine.ts", "src/main/ipc.ts"]
}
