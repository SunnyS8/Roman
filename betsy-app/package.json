{
  "name": "betsy-app",
  "version": "0.2.0-rc3",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite dev",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win --x64",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json",
    "pretest": "node scripts/use-node-abi.cjs",
    "test": "vitest run",
    "pretest:e2e": "node scripts/use-electron-abi.cjs && npm run build",
    "preelectron": "node scripts/use-electron-abi.cjs",
    "test:e2e": "playwright test",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "electron-updater": "^6.3.9",
    "ssh2": "^1.15.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.49.0",
    "postcss": "^8.4.49",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
