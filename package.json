{
  "name": "betsy",
  "version": "0.1.0",
  "description": "Betsy — AI assistant companion with personality, voice, video circles, and self-learning",
  "license": "MIT",
  "author": "Betsy",
  "type": "module",
  "bin": {
    "betsy": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:ui": "vite build",
    "build:all": "tsup && vite build",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "auth-relay": "tsx src/auth-relay/server.ts",
    "auth-relay:build": "tsup src/auth-relay/server.ts --format cjs --out-dir dist/auth-relay",
    "auth-relay:sim": "tsx src/auth-relay/sim.ts"
  },
  "optionalDependencies": {
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@google-cloud/storage": "^7.19.0",
    "@google/adk": "^0.6.1",
    "@google/genai": "^1.48.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^11.8.0",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.35.0",
    "js-yaml": "^4.1.1",
    "minisearch": "^7.2.0",
    "openai": "^4.80.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "pino": "^10.3.1",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "uuid": "^11.1.0",
    "viem": "^2.23.0",
    "wouter": "^3.9.0",
    "ws": "^8.19.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
